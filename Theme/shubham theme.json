{
  "name": "ML Dashboard Pro - Cyber Slate Dark",
  "dataColors": [
    "#FF2A54",
    "#FF9F00",
    "#00E676",
    "#00B0FF",
    "#D500F9",
    "#ECEFF1",
    "#374151",
    "#111827"
  ],
  "background": "#0D1117",
  "foreground": "#1F293D",
  "tableAccent": "#FF2A54",
  "visualStyles": {
    "*": {
      "*": {
        "outlines": [
          {
            "show": false
          }
        ],
        "dropShadow": [
          {
            "show": false
          }
        ],
        "title": [
          {
            "show": true,
            "fontColor": { "solid": { "color": "#FFFFFF" } },
            "fontSize": 12,
            "fontFamily": "Segoe UI Semibold"
          }
        ]
      }
    },
    "tableEx": {
      "*": {
        "grid": [
          {
            "gridBorder": true,
            "gridBorderColor": { "solid": { "color": "#2D3748" } },
            "gridBorderWidth": 1,
            "horizontalGrid": true,
            "horizontalGridColor": { "solid": { "color": "#2D3748" } },
            "horizontalGridWidth": 1,
            "verticalGrid": false
          }
        ],
        "columnHeaders": [
          {
            "fontColor": { "solid": { "color": "#FFFFFF" } },
            "backColor": { "solid": { "color": "#1F293D" } },
            "fontFamily": "Segoe UI Semibold",
            "fontSize": 10
          }
        ],
        "values": [
          {
            "fontColor": { "solid": { "color": "#E2E8F0" } },
            "backColor": { "solid": { "color": "#161D30" } },
            "fontFamily": "Segoe UI",
            "fontSize": 10
          }
        ],
        "alternateValues": [
          {
            "fontColor": { "solid": { "color": "#E2E8F0" } },
            "backColor": { "solid": { "color": "#1F293D" } },
            "fontFamily": "Segoe UI",
            "fontSize": 10
          }
        ]
      }
    },
    "pivotTable": {
      "*": {
        "grid": [
          {
            "gridBorder": true,
            "gridBorderColor": { "solid": { "color": "#2D3748" } },
            "gridBorderWidth": 1,
            "horizontalGrid": true,
            "horizontalGridColor": { "solid": { "color": "#2D3748" } },
            "horizontalGridWidth": 1,
            "verticalGrid": false
          }
        ],
        "columnHeaders": [
          {
            "fontColor": { "solid": { "color": "#FFFFFF" } },
            "backColor": { "solid": { "color": "#1F293D" } },
            "fontFamily": "Segoe UI Semibold",
            "fontSize": 10
          }
        ],
        "rowHeaders": [
          {
            "fontColor": { "solid": { "color": "#FFFFFF" } },
            "backColor": { "solid": { "color": "#161D30" } },
            "fontFamily": "Segoe UI Semibold",
            "fontSize": 10
          }
        ],
        "values": [
          {
            "fontColor": { "solid": { "color": "#E2E8F0" } },
            "backColor": { "solid": { "color": "#161D30" } },
            "fontFamily": "Segoe UI",
            "fontSize": 10
          }
        ],
        "alternateValues": [
          {
            "fontColor": { "solid": { "color": "#E2E8F0" } },
            "backColor": { "solid": { "color": "#1F293D" } },
            "fontFamily": "Segoe UI",
            "fontSize": 10
          }
        ]
      }
    },
    "card": {
      "*": {
        "labels": [
          {
            "fontColor": { "solid": { "color": "#FFFFFF" } },
            "fontFamily": "Segoe UI Semibold",
            "fontSize": 28
          }
        ],
        "categoryLabels": [
          {
            "show": true,
            "fontColor": { "solid": { "color": "#A0AEC0" } },
            "fontFamily": "Segoe UI",
            "fontSize": 10
          }
        ]
      }
    },
    "multiRowCard": {
      "*": {
        "cardTitle": [
          {
            "fontColor": { "solid": { "color": "#FFFFFF" } },
            "fontFamily": "Segoe UI Semibold",
            "fontSize": 12
          }
        ],
        "cardValues": [
          {
            "fontColor": { "solid": { "color": "#FFFFFF" } },
            "fontFamily": "Segoe UI Semibold",
            "fontSize": 20
          }
        ],
        "categoryLabels": [
          {
            "fontColor": { "solid": { "color": "#A0AEC0" } },
            "fontFamily": "Segoe UI",
            "fontSize": 10
          }
        ]
      }
    },
    "slicer": {
      "*": {
        "header": [
          {
            "fontColor": { "solid": { "color": "#FFFFFF" } },
            "fontFamily": "Segoe UI Semibold",
            "fontSize": 10
          }
        ],
        "items": [
          {
            "fontColor": { "solid": { "color": "#E2E8F0" } },
            "background": { "solid": { "color": "#1F293D" } },
            "fontFamily": "Segoe UI",
            "fontSize": 10
          }
        ]
      }
    }
  }
}